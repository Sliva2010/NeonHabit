# Отключить авто-конверсию окончаний строк для shell-скриптов
gradlew text eol=lf
gradlew.bat text eol=crlf

# Kotlin
*.kt text eol=lf

# Gradle scripts
*.gradle text eol=lf
*.gradle.kts text eol=lf

# Properties
*.properties text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf

# Shell scripts
*.sh text eol=lf
